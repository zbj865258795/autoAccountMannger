# ─── 数据库配置 ────────────────────────────────────────────────────────────────
# MySQL 容器配置（docker-compose 使用，一般无需修改）
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=account_manager
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword

# MySQL 对外映射端口（默认 3307，避免与其他 MySQL 容器的 3306 冲突）
MYSQL_PORT=3307

# ─── 应用配置 ──────────────────────────────────────────────────────────────────
# Cookie 签名密钥（必填，请替换为随机字符串，至少 32 位）
# 可直接使用下面这串，或自行生成：openssl rand -hex 64
JWT_SECRET=change-this-to-a-random-secret-string

# 应用访问端口（默认 3000）
APP_PORT=3000

# ─── 以下为 Manus 云平台专用，本地部署留空即可 ────────────────────────────────
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
